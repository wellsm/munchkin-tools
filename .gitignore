# Convex
# _generated/{api,server,dataModel}.* are committed so Docker builds don't
# need network/auth to produce the types — they are regenerated by
# `convex dev/codegen` locally when the schema changes. The ai/ subfolder
# holds agent tooling state and is not needed at build time.
packages/convex/convex/_generated/ai/
.convex/
tsconfig.tsbuildinfo

