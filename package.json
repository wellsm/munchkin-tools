{
  "name": "munchkin-tools",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -c cyan,magenta --kill-others-on-fail \"npm:dev:*\"",
    "dev:web": "npm run dev --workspace=@munchkin-tools/web",
    "dev:convex": "npm run dev --workspace=@munchkin-tools/convex",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}